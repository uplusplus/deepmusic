// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 乐谱
model Score {
  id          String   @id @default(uuid())
  title       String
  composer    String
  arranger    String?
  difficulty  String @default("BEGINNER")
  
  // 文件信息
  musicXmlPath String
  coverImage   String?
  fileSize     Int
  
  // 元数据
  duration     Int
  measures     Int
  timeSignature String @default("4/4")
  keySignature  String @default("C Major")
  tempo        Int     @default(120)
  
  // 分类
  category    String?
  tags        Tag[]
  
  // 统计
  playCount   Int      @default(0)
  favoriteCount Int    @default(0)
  
  // 状态
  status      String @default("DRAFT")
  isPublic    Boolean     @default(true)
  
  // 版权信息
  source      String?
  license     String?
  copyright   String?
  
  // 时间戳
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  
  // 关系
  practiceRecords  PracticeRecord[]
  practiceSessions PracticeSession[]
  favorites        User[]            @relation("UserFavorites")

  @@index([title])
  @@index([composer])
  @@index([difficulty])
  @@index([category])
}

// 标签
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  scores    Score[]

  @@index([name])
}

// 用户
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  nickname      String?
  avatar        String?
  
  // 统计
  totalPracticeTime Int   @default(0)
  totalSessions     Int   @default(0)
  totalNotes        Int   @default(0)
  
  // 关系
  practiceRecords  PracticeRecord[]
  practiceSessions PracticeSession[]
  favorites        Score[]          @relation("UserFavorites")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 练习记录
model PracticeRecord {
  id        String   @id @default(uuid())
  userId    String
  scoreId   String
  
  duration      Int
  notesPlayed   Int
  pitchScore    Float
  rhythmScore   Float
  overallScore  Float
  grade         String
  details       String?
  
  startedAt     DateTime
  completedAt   DateTime @default(now())
  
  user          User    @relation(fields: [userId], references: [id])
  score         Score   @relation(fields: [scoreId], references: [id])

  @@index([userId])
  @@index([scoreId])
  @@index([completedAt])
}

// 活跃练习会话 (持久化，替代内存 Map)
model PracticeSession {
  id        String   @id @default(uuid())
  userId    String
  scoreId   String
  startedAt DateTime
  
  // 状态: ACTIVE, COMPLETED, ABANDONED
  status    String   @default("ACTIVE")
  
  // 累计音符事件 (JSON 数组，定期追加)
  noteEvents String  @default("[]")
  
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id])
  score     Score    @relation(fields: [scoreId], references: [id])

  @@index([userId])
  @@index([scoreId])
  @@index([status])
}

// 设备
model Device {
  id            String   @id @default(uuid())
  userId        String?
  name          String
  manufacturer  String?
  model         String?
  lastConnected DateTime?
  createdAt     DateTime @default(now())
}
