# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deepmusic?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Storage (本地开发用本地文件系统)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# 生产环境使用云存储
# STORAGE_TYPE=aliyun
# ALIYUN_OSS_REGION=oss-cn-shanghai
# ALIYUN_OSS_BUCKET=deepmusic-scores
# ALIYUN_ACCESS_KEY_ID=your-key-id
# ALIYUN_ACCESS_KEY_SECRET=your-key-secret
